<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CodeWF.Markdown.Lite.Themes.Themes.CompactTypographyResources">
    <x:Double x:Key="CodeWFMarkdownParagraphFontSize">14</x:Double>
    <x:Double x:Key="CodeWFMarkdownParagraphLineHeight">22</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading1FontSize">26</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading2FontSize">22</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading3FontSize">19</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading4FontSize">17</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading5FontSize">15</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading6FontSize">14</x:Double>
    <x:Double x:Key="CodeWFMarkdownBlockSpacing">4</x:Double>
    <x:Double x:Key="CodeWFMarkdownDocumentBottomPadding">40</x:Double>
    <Thickness x:Key="CodeWFMarkdownParagraphMargin">0 2 0 6</Thickness>
    <Thickness x:Key="CodeWFMarkdownHeadingMargin">0 10 0 6</Thickness>
    <Thickness x:Key="CodeWFMarkdownHeading2BorderThickness">0 0 0 1</Thickness>
    <Thickness x:Key="CodeWFMarkdownHeading2Padding">0 0 0 4</Thickness>

    <x:Double x:Key="CodeWFMarkdownCodeBlockFontSize">12</x:Double>
    <x:Double x:Key="CodeWFMarkdownCodeBlockLineHeight">18</x:Double>
    <x:Double x:Key="CodeWFMarkdownCodeLanguageFontSize">11</x:Double>
    <CornerRadius x:Key="CodeWFMarkdownCodeBlockCornerRadius">6</CornerRadius>
    <Thickness x:Key="CodeWFMarkdownCodeBlockPadding">8</Thickness>
    <Thickness x:Key="CodeWFMarkdownCodeBlockMargin">0 5 0 8</Thickness>
    <x:Double x:Key="CodeWFMarkdownCodeBlockSpacing">4</x:Double>
    <x:Double x:Key="CodeWFMarkdownCodeBlockHeaderSpacing">6</x:Double>
    <x:Double x:Key="CodeWFMarkdownCopyButtonMinWidth">48</x:Double>
    <x:Double x:Key="CodeWFMarkdownCopyButtonHeight">24</x:Double>
    <Thickness x:Key="CodeWFMarkdownCopyButtonPadding">8 0</Thickness>
    <CornerRadius x:Key="CodeWFMarkdownCopyButtonCornerRadius">4</CornerRadius>

    <x:Double x:Key="CodeWFMarkdownListSpacing">3</x:Double>
    <Thickness x:Key="CodeWFMarkdownListMargin">0 1 0 5</Thickness>
    <Thickness x:Key="CodeWFMarkdownListItemMargin">0 1 0 1</Thickness>
    <x:Double x:Key="CodeWFMarkdownListItemContentSpacing">2</x:Double>
    <Thickness x:Key="CodeWFMarkdownListMarkerMargin">0 0 6 0</Thickness>
    <Thickness x:Key="CodeWFMarkdownTaskMarkerBoxMargin">0</Thickness>
    <x:Double x:Key="CodeWFMarkdownUnorderedListMarkerWidth">20</x:Double>
    <x:Double x:Key="CodeWFMarkdownOrderedListMarkerMinWidth">24</x:Double>
    <x:Double x:Key="CodeWFMarkdownOrderedListMarkerCharacterWidth">8</x:Double>
    <x:Double x:Key="CodeWFMarkdownOrderedListMarkerExtraWidth">4</x:Double>
    <Thickness x:Key="CodeWFMarkdownListFirstParagraphMargin">0 0 0 1</Thickness>
    <Thickness x:Key="CodeWFMarkdownListNestedParagraphMargin">0 1 0 1</Thickness>

    <Thickness x:Key="CodeWFMarkdownQuoteBorderThickness">3 0 0 0</Thickness>
    <CornerRadius x:Key="CodeWFMarkdownQuoteCornerRadius">5</CornerRadius>
    <Thickness x:Key="CodeWFMarkdownQuotePadding">10 6</Thickness>
    <Thickness x:Key="CodeWFMarkdownQuoteMargin">0 4 0 8</Thickness>
    <x:Double x:Key="CodeWFMarkdownQuoteContentSpacing">3</x:Double>
    <Thickness x:Key="CodeWFMarkdownThematicBreakMargin">0 10 0 10</Thickness>

    <Thickness x:Key="CodeWFMarkdownTableMargin">0 5 0 8</Thickness>
    <Thickness x:Key="CodeWFMarkdownTableCellPadding">8 5</Thickness>
    <x:Double x:Key="CodeWFMarkdownTableCellMinHeight">28</x:Double>
    <x:Double x:Key="CodeWFMarkdownTableCellContentSpacing">2</x:Double>

    <Thickness x:Key="CodeWFMarkdownImageMargin">0 4 0 8</Thickness>
    <Thickness x:Key="CodeWFMarkdownImageFallbackPadding">8</Thickness>
    <Thickness x:Key="CodeWFMarkdownImageFallbackMargin">0 4 0 8</Thickness>
    <Thickness x:Key="CodeWFMarkdownImagePreviewContentPadding">16</Thickness>
    <x:Double x:Key="CodeWFMarkdownImagePreviewToolbarSpacing">6</x:Double>
    <Thickness x:Key="CodeWFMarkdownImagePreviewToolbarMargin">8</Thickness>
    <x:Double x:Key="CodeWFMarkdownImagePreviewZoomTextMinWidth">52</x:Double>
    <Thickness x:Key="CodeWFMarkdownImagePreviewButtonPadding">10 4</Thickness>
</ResourceDictionary>

