<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CodeWF.Markdown.Themes.Themes.BasicTypographyResources">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#24292F" />
            <SolidColorBrush x:Key="CodeWFMarkdownBorderBrush" Color="#D0D7DE" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#F6F8FA" />
            <SolidColorBrush x:Key="CodeWFMarkdownCodeBackgroundBrush" Color="#F6F8FA" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#F6F8FA" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#F6F8FA" />
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="CodeWFMarkdownAccentBrush" Color="#F0F6FC" />
            <SolidColorBrush x:Key="CodeWFMarkdownBorderBrush" Color="#30363D" />
            <SolidColorBrush x:Key="CodeWFMarkdownQuoteBackgroundBrush" Color="#11161D" />
            <SolidColorBrush x:Key="CodeWFMarkdownCodeBackgroundBrush" Color="#0D1117" />
            <SolidColorBrush x:Key="CodeWFMarkdownInlineCodeBackgroundBrush" Color="#161B22" />
            <SolidColorBrush x:Key="CodeWFMarkdownTableHeaderBackgroundBrush" Color="#161B22" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <x:Double x:Key="CodeWFMarkdownParagraphFontSize">16</x:Double>
    <x:Double x:Key="CodeWFMarkdownParagraphLineHeight">26</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading1FontSize">32</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading2FontSize">24</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading3FontSize">20</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading4FontSize">18</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading5FontSize">16</x:Double>
    <x:Double x:Key="CodeWFMarkdownHeading6FontSize">16</x:Double>
    <Thickness x:Key="CodeWFMarkdownTableMargin">0 10 0 16</Thickness>
    <Thickness x:Key="CodeWFMarkdownTableContainerBorderThickness">1</Thickness>
    <CornerRadius x:Key="CodeWFMarkdownTableCornerRadius">6</CornerRadius>
    <Thickness x:Key="CodeWFMarkdownTableCellBorderThickness">1</Thickness>
    <Thickness x:Key="CodeWFMarkdownTableCellPadding">10 8</Thickness>
    <x:Double x:Key="CodeWFMarkdownTableCellMinHeight">34</x:Double>
    <x:Double x:Key="CodeWFMarkdownTableCellContentSpacing">0</x:Double>
</ResourceDictionary>
