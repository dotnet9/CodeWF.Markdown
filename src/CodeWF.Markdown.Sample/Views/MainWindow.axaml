<Window
    x:Class="CodeWF.Markdown.Sample.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="https://codewf.com"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sample="clr-namespace:CodeWF.Markdown.Sample"
    xmlns:l="clr-namespace:CodeWF.Markdown"
    xmlns:views="using:CodeWF.Markdown.Sample.Views"
    xmlns:vm="using:CodeWF.Markdown.Sample.ViewModels"
    Title="{c:I18n {x:Static l:SampleL.WindowTitle}}"
    Width="1280"
    Height="820"
    MinWidth="980"
    MinHeight="640"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/logo.ico"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.toolbar-shell">
            <Setter Property="Padding" Value="14 10" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="0 0 0 1" />
        </Style>
        <Style Selector="Border.toolbar-group">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Margin" Value="0 0 10 0" />
            <Setter Property="Padding" Value="10 6" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style Selector="ComboBox.toolbar-combo">
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Height" Value="30" />
        </Style>
        <Style Selector="ComboBox.typography-combo">
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Height" Value="30" />
        </Style>
        <Style Selector="ComboBox.language-combo">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="30" />
        </Style>
        <Style Selector="ToggleSwitch.compact-toggle">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TabControl.preview-tabs">
            <Setter Property="Margin" Value="12 8 12 12" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="14 8" />
        </Style>
        <Style Selector="Button.stress-toggle">
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12 0" />
        </Style>
    </Window.Styles>

    <Window.Resources>
        <DataTemplate x:Key="LanguageSelectionTemplate" x:DataType="sample:SampleLanguage">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                <TextBlock Foreground="#64748B" Text="{Binding DisplayTag}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*">
        <Border Classes="toolbar-shell">
            <Grid ColumnDefinitions="*,Auto">
                <WrapPanel
                    ItemHeight="42"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <Border Classes="toolbar-group">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="label" Text="{c:I18n {x:Static l:SampleL.AppTheme}}" />
                            <ComboBox
                                Classes="toolbar-combo"
                                DisplayMemberBinding="{Binding Name}"
                                ItemsSource="{Binding ThemeVariants}"
                                SelectedItem="{Binding SelectedThemeVariant}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="toolbar-group">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="label" Text="{c:I18n {x:Static l:SampleL.TypographyTheme}}" />
                            <ComboBox
                                Classes="typography-combo"
                                DisplayMemberBinding="{Binding Name}"
                                ItemsSource="{Binding TypographyThemes}"
                                SelectedItem="{Binding SelectedTypographyTheme}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="toolbar-group">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="label" Text="{c:I18n {x:Static l:SampleL.CompactLayout}}" />
                            <ToggleSwitch Classes="compact-toggle" IsChecked="{Binding IsCompactLayout}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Grid.Column="1" Classes="toolbar-group" Margin="8 0 0 0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="label" Text="{c:I18n {x:Static l:SampleL.Language}}" />
                        <ComboBox
                            Classes="language-combo"
                            ItemTemplate="{StaticResource LanguageSelectionTemplate}"
                            ItemsSource="{Binding Languages}"
                            SelectedItem="{Binding SelectLanguage, Mode=TwoWay}"
                            SelectionBoxItemTemplate="{StaticResource LanguageSelectionTemplate}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl
            x:Name="PreviewTabs"
            Grid.Row="1"
            Classes="preview-tabs">
            <TabItem Header="编辑预览">
                <views:MarkdownEditorPreviewView />
            </TabItem>
            <TabItem Header="多 Viewer">
                <views:MarkdownViewerPairDemoView />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
