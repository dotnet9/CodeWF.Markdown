<UserControl
    x:Class="CodeWF.Markdown.Sample.Views.MarkdownEditorPreviewView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="https://codewf.com"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:edit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
    xmlns:l="clr-namespace:CodeWF.Markdown"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="https://codewf.com"
    xmlns:vm="using:CodeWF.Markdown.Sample.ViewModels"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460" MinWidth="300" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" MinWidth="360" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Padding="14"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0 0 1 0">
            <Grid RowDefinitions="Auto,Auto,*">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{c:I18n {x:Static l:SampleL.MarkdownInput}}" />
                <Grid
                    Grid.Row="1"
                    Margin="0 10 0 12"
                    ColumnDefinitions="*,Auto">
                    <ComboBox
                        Margin="0 0 10 0"
                        DisplayMemberBinding="{Binding Name}"
                        ItemsSource="{Binding MarkdownFiles}"
                        SelectedItem="{Binding SelectedFile}" />
                    <Button
                        Grid.Column="1"
                        Classes="stress-toggle"
                        Command="{Binding ToggleIncrementalStressCommand}"
                        Content="{Binding IncrementalStressButtonText}" />
                </Grid>
                <edit:TextEditor
                    x:Name="MarkdownEditor"
                    Grid.Row="2"
                    FontFamily="Consolas, Cascadia Mono"
                    FontSize="13"
                    HorizontalScrollBarVisibility="Auto"
                    ShowLineNumbers="True"
                    VerticalScrollBarVisibility="Auto"
                    WordWrap="True" />
            </Grid>
        </Border>

        <GridSplitter
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
            ResizeDirection="Columns" />

        <Border
            Grid.Column="2"
            Padding="34 28 34 0">
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <md:MarkdownViewer Markdown="{Binding Markdown}" />
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
